[Unit]
Description=Score Teacher — sheet music reading trainer
After=network.target

[Service]
Type=simple
WorkingDirectory=/root/score-teacher
ExecStartPre=/usr/bin/npm run build
ExecStart=/usr/bin/npx vite preview --port 3300 --host
Restart=on-failure
RestartSec=5
Environment=NODE_ENV=production

[Install]
WantedBy=multi-user.target
